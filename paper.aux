\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Dvipada end-to-end constrained decoding results ($n=102$ poems per row; 3 prompts $\times $ 34 seeds). The \textit  {adapted Chandomitra} rows are our port of the Algorithm~1 of~\citet  {jagadeeshan2026chandomitra} (originally designed for Sanskrit Anu\d {s}\d {t}ubh, 99.86\% on its native task) to the Dvipada rule set, applied to the same models, prompts, and seeds. All three FST+NFA strategies share the same per-step NFA alive-predicate filter; they differ only in recovery (backtracking) and accept-state re-ranking (hybrid).}}{8}{table.caption.19}\protected@file@percent }
\newlabel{tab:dvipada-results}{{6}{8}{Dvipada end-to-end constrained decoding results ($n=102$ poems per row; 3 prompts $\times $ 34 seeds). The \textit {adapted Chandomitra} rows are our port of the Algorithm~1 of~\citet {jagadeeshan2026chandomitra} (originally designed for Sanskrit Anu\d {s}\d {t}ubh, 99.86\% on its native task) to the Dvipada rule set, applied to the same models, prompts, and seeds. All three FST+NFA strategies share the same per-step NFA alive-predicate filter; they differ only in recovery (backtracking) and accept-state re-ranking (hybrid)}{table.caption.19}{}}
\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces Ragale end-to-end constrained decoding results ($n=102$ poems per row; 3 prompts $\times $ 34 seeds). All three strategies share the same per-step NFA alive-predicate filter; hybrid additionally applies an accept-state re-ranking pass over the masked top-$100$.}}{8}{table.caption.20}\protected@file@percent }
\newlabel{tab:ragale-results}{{7}{8}{Ragale end-to-end constrained decoding results ($n=102$ poems per row; 3 prompts $\times $ 34 seeds). All three strategies share the same per-step NFA alive-predicate filter; hybrid additionally applies an accept-state re-ranking pass over the masked top-$100$}{table.caption.20}{}}
